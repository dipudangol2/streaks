// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

enum FREQUENCY {
  DAILY
  WEEKLY
  MONTHLY
}
generator client {
  provider = "prisma-client-js"
  // output = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  habits    Habit[]  @relation("UserHabits")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isAdmin   Boolean  @default(false)
}

model Habit {
  id          String         @id @default(uuid())
  title       String
  description String?
  frequency   FREQUENCY      @default(DAILY)
  startDate   DateTime
  archived    Boolean        @default(false)
  userId      String
  user        User           @relation("UserHabits", fields: [userId], references: [id])
  checkins    HabitCheckin[]
  streak      Streak?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // @@unique([userId,title,description,startDate,frequency]) // Ensure a user cannot have two habits with the same details
}

model HabitCheckin {
  id      String   @id @default(uuid())
  habitId String
  date    DateTime // Date of check-in (no duplicates for same habit + date)
  habit   Habit    @relation(fields: [habitId], references: [id])

  @@unique([habitId, date]) // Ensures one check-in per habit per day
}

model Streak {
  id              String    @id @default(uuid())
  habitId         String    @unique
  currentCount    Int       @default(0)
  longestCount    Int       @default(0)
  lastCheckinDate DateTime?
  habit           Habit     @relation(fields: [habitId], references: [id])
}
